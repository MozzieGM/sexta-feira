# ============================================================
# SEXTA-FEIRA — Variáveis de Ambiente (PRIVADO)
# ============================================================

# --- API Key do Groq (LLM + Whisper STT) ---
# Substitua pelo seu token real
GROQ_API_KEY=gsk_SUA_CHAVE_REAL_AQUI

# --- IPs dos Microcontroladores ESP32 na rede local ---
# Insira o endereço IP atribuído ao ESP32 pelo seu roteador.
# Exemplos comuns: http://192.168.1.15, http://10.0.0.50, etc.

IP_ESP32_MASCARA=http://192.168.0.xxx
IP_ESP32_REATOR=http://192.168.0.xxx

# DICA: Verifique o Monitor Serial na IDE do Arduino para encontrar o IP após a conexão.

# --- Configuração do Servidor ---
SERVER_PORT=8000

# --- Configuração MQTT (Mosquitto) ---
MQTT_HOST=mosquitto
MQTT_PORT=1883