# ============================================================
# SEXTA-FEIRA — Configuração do Satélite PC
# ============================================================
# Configure estas variáveis para cada PC/cômodo da casa.
# ============================================================

# --- Endereço do Cérebro Central ---
# Se o cérebro roda no mesmo PC: http://localhost:8000
# Se roda em outro PC/Docker: http://{IP_DO_CEREBRO}:8000
CEREBRO_URL=http://192.168.0.xxx:8000

# --- Configuração MQTT ---
# Deve apontar para o mesmo broker do Cérebro
MQTT_HOST=localhost
MQTT_PORT=1883

# --- Identificação deste Satélite ---
# NOME_COMODO define em qual tópico MQTT este PC escuta
# Exemplos: escritorio, sala, quarto, laboratorio
NOME_COMODO=escritorio
NOME_DISPOSITIVO=pc_principal
